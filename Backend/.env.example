PORT=4000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_change_in_production
DATABASE_PATH=./data/app.db
UPLOAD_DIR=./uploads
CORS_ORIGIN=http://localhost:3000

# Optional: Set a custom password for the default admin account
# If not set, a random password will be generated and displayed on first run
# ADMIN_PASSWORD=your_secure_admin_password

# Email Configuration (choose one)
# Option 1: Gmail SMTP (requires App Password, not regular password)
# EMAIL_USER=your-gmail@gmail.com
# EMAIL_PASS=your_app_password_16_chars

# Option 2: Resend API (recommended)
# RESEND_API_KEY=your_resend_api_key

# SMS Configuration (Twilio)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone_number
